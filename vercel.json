{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/:path*.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/:path*.js",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    }
  ]
}
